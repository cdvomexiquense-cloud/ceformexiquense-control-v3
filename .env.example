# Conexion a MongoDB (local o MongoDB Atlas)
# Para desarrollo local: mongodb://localhost:27017
# Para produccion: usa la cadena de conexion de MongoDB Atlas
MONGO_URL=mongodb://localhost:27017

# Nombre de la base de datos
DB_NAME=academia_futbol

# URL publica de tu app (usada por Next.js)
# En produccion debe ser tu dominio de Vercel: https://tu-app.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# CORS (deja en *)
CORS_ORIGINS=*

# Credenciales del administrador (cambialas en produccion)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Secreto para firmar la sesion. Genera una cadena aleatoria larga.
# Puedes generar una con: openssl rand -hex 32
AUTH_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio
